{
  "name": "usako-worker",
  "version": "1.0.0",
  "description": "LINE Bot with Google Sheets integration on Cloudflare Workers",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "testMatch": [
      "<rootDir>/src/**/*.test.ts"
    ]
  },
  "keywords": [
    "cloudflare-workers",
    "line-bot",
    "google-sheets"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240104.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "wrangler": "^3.22.1"
  },
  "dependencies": {
    "@line/bot-sdk": "^8.4.1",
    "google-spreadsheet": "^3.3.0",
    "googleapis": "^129.0.0"
  }
}
